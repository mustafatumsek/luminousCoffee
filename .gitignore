# ─── macOS System Files ───
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
desktop.ini

# ─── Firebase Cache & Logs ───
.firebase/
firebase-debug.log*
firebase-debug.*.log*
ui-debug.log*

# ─── Node / npm ───
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.eslintcache
*.tgz
.yarn-integrity

# ─── Environment Variables ───
.env
.env.local
.env.*.local

# ─── IDE / Editor ───
.vscode/
.idea/
*.swp
*.swo
*~

# ─── Runtime ───
pids
*.pid
*.seed
*.pid.lock

# ─── Coverage ───
coverage/
.nyc_output/

# ─── Firebase Data Connect ───
.dataconnect
